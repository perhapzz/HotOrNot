# HotOrNot Docker 部署环境变量模板
# 使用方法: cp .env.docker .env && 编辑 .env 文件填入真实值

# ==================== 必需的API配置 ====================
# TikHub API Key - 用于小红书和抖音数据获取 (必需)
# 注册地址: https://tikhub.io
TIKHUB_API_KEY=your_tikhub_api_key_here

# AI服务API Key - 用于内容分析 (至少配置一个)
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ==================== 数据库配置 ====================
# MongoDB连接字符串 (Docker环境下通常使用容器名)
DATABASE_URL=mongodb://mongo:27017/hotornot
MONGODB_URI=mongodb://mongo:27017/hotornot

# ==================== 功能配置 ====================
USE_REAL_ANALYSIS=true
ALLOW_FALLBACK_DATA=false
AUTO_START_SCHEDULER=prod

# ==================== Docker构建配置 ====================
SKIP_DATABASE_CONNECTION=true