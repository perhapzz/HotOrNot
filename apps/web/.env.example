# Local Environment Configuration
# 复制并重命名此文件为 .env.local，然后配置你的实际值

# 启用真实分析服务 (设为 false 使用模拟数据进行测试)
USE_REAL_ANALYSIS=true

# MongoDB 数据库连接
MONGODB_URI=mongodb://localhost:27017/hotornot

# TikHub API 配置 (需要真实分析时取消注释并填入真实值)
# TIKHUB_API_KEY=your_actual_api_key_here
# TIKHUB_XIAOHONGSHU_API_URL=https://api.tikhub.io/api/v1/xiaohongshu/web_v2/fetch_home_notes
# TIKHUB_XIAOHONGSHU_SEARCH_API_URL=https://api.tikhub.io/api/v1/xiaohongshu/web_v2/fetch_search_notes
# TIKHUB_DOUYIN_API_URL=https://api.tikhub.io/api/v1/douyin/app/v3/fetch_user_post_videos

# 控制是否允许降级到模拟数据 (设为 false 将在API失败时直接报错)
ALLOW_FALLBACK_DATA=false

# TikHub API配置
# 在 https://tikhub.io 注册账号并获取API密钥
TIKHUB_API_KEY=""

# AI服务配置
GEMINI_API_KEY=""
DEEPSEEK_API_KEY=""
OPENAI_API_KEY=""

# 数据库配置
DATABASE_URL=mongodb://localhost:27017/hotornot

# 定时器自动启动策略
# 可选值:
# - prod/production: 仅在生产环境自动启动
# - dev/development: 仅在开发环境自动启动  
# - all/always: 所有环境都自动启动 (默认)
# - none/disabled: 禁用自动启动，需要手动启动
AUTO_START_SCHEDULER=all

# 缓存配置
KEYWORD_ANALYSIS_CACHE_HOURS=24
CONTENT_ANALYSIS_CACHE_HOURS=6
ACCOUNT_ANALYSIS_CACHE_HOURS=12
HOTLIST_DATA_CACHE_HOURS=3

# 其他配置
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000